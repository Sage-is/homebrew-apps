#!/bin/bash
set -euo pipefail

IMAGE="ghcr.io/sage-is/ai-ui:latest"
CONTAINER="sage-ai"
VOLUME="sage-ai-data"
DATA_MOUNT="/app/backend/data"
DEFAULT_PORT=8080

usage() {
  cat <<EOF
Usage: ai-ui <command> [options]

Commands:
  start [--port PORT]   Pull image and start Sage AI UI (default port: $DEFAULT_PORT)
  stop                  Stop the running container
  update                Pull latest image and restart
  logs                  Tail container logs
  open                  Open the UI in your default browser
  status                Show container status

EOF
}

# Ensure Docker is reachable.
ensure_docker() {
  if docker info &>/dev/null; then
    return 0
  fi

  echo "Error: Cannot connect to Docker."
  echo "  Make sure Docker Desktop is running, or start the Docker daemon."
  echo "  Install: https://docs.docker.com/get-docker/"
  exit 1
}

cmd_start() {
  local port=$DEFAULT_PORT
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --port) port="$2"; shift 2 ;;
      *) echo "Unknown option: $1"; usage; exit 1 ;;
    esac
  done

  ensure_docker

  echo "Pulling latest image..."
  docker pull "$IMAGE"

  # Stop existing container if running
  docker rm -f "$CONTAINER" 2>/dev/null || true

  echo "Starting Sage AI UI on port $port..."
  docker run -d \
    -p "$port:8080" \
    -v "$VOLUME:$DATA_MOUNT" \
    --name "$CONTAINER" \
    "$IMAGE"

  echo ""
  echo "Sage AI UI is running at http://localhost:$port"
  echo "Run 'ai-ui open' to open in your browser."
}

cmd_stop() {
  echo "Stopping Sage AI UI..."
  docker stop "$CONTAINER" 2>/dev/null || true
  docker rm "$CONTAINER" 2>/dev/null || true
  echo "Stopped."
}

cmd_update() {
  echo "Pulling latest image..."
  docker pull "$IMAGE"
  cmd_stop
  cmd_start "$@"
}

cmd_logs() {
  docker logs -f "$CONTAINER"
}

cmd_open() {
  local port
  port=$(docker port "$CONTAINER" 8080 2>/dev/null | head -1 | cut -d: -f2)
  if [[ -z "$port" ]]; then
    echo "Container is not running. Start it first with: ai-ui start"
    exit 1
  fi
  open "http://localhost:$port"
}

cmd_status() {
  docker inspect --format='Status: {{.State.Status}}' "$CONTAINER" 2>/dev/null || echo "Container is not running."
  local port
  port=$(docker port "$CONTAINER" 8080 2>/dev/null | head -1 | cut -d: -f2)
  if [[ -n "$port" ]]; then
    echo "URL: http://localhost:$port"
  fi
}

if [[ $# -eq 0 ]]; then
  usage
  exit 0
fi

command="$1"; shift
case "$command" in
  start)  cmd_start "$@" ;;
  stop)   cmd_stop ;;
  update) cmd_update "$@" ;;
  logs)   cmd_logs ;;
  open)   cmd_open ;;
  status) cmd_status ;;
  -h|--help|help) usage ;;
  *) echo "Unknown command: $command"; usage; exit 1 ;;
esac
