#!/bin/bash
set -euo pipefail

VERSION="1.1.0"

# ---------------------------------------------------------------------------
# Canonical distribution facts.
# ---------------------------------------------------------------------------
# These mirror values in distribution.env (hardlinked across homebrew-apps,
# WEB-AI--Sage-is-AI-UI, WEB-Sage.Education-docs). When running this script
# from a development checkout, distribution.env (next to the script) overrides
# the hardcoded defaults. Brew-installed users get the defaults below.
#
# Bumping these without bumping VERSION is a footgun — they go together.

IMAGE_REGISTRY="ghcr.io/sage-is/ai-ui"
DEFAULT_SERVER_TAG="latest"
CONTAINER="sage-ai"
VOLUME="sage-ai-data"
DATA_MOUNT="/app/backend/data"
DEFAULT_PORT=8080

# Source distribution.env if we're running from a checkout (overrides defaults).
_script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -f "$_script_dir/distribution.env" ]]; then
  set -a
  # shellcheck source=/dev/null
  source "$_script_dir/distribution.env"
  set +a
  IMAGE_REGISTRY="${IMAGE:-$IMAGE_REGISTRY}"
  DEFAULT_SERVER_TAG="${SERVER_TAG:-$DEFAULT_SERVER_TAG}"
  VOLUME="${VOLUME:-$VOLUME}"
  DATA_MOUNT="${DATA_MOUNT:-$DATA_MOUNT}"
fi

# Active image tag. Overridable per-invocation via `--tag X.Y.Z`.
IMAGE_TAG="$DEFAULT_SERVER_TAG"
IMAGE="$IMAGE_REGISTRY:$IMAGE_TAG"

# try.sage trial mode runs the same image with ENABLE_TRY_SAGE=true. Separate
# container + volume so a workstation can keep its prod install around without
# data cross-contamination — though both bind 8080, so only one runs at a time.
TRY_CONTAINER="sage-try"
TRY_VOLUME="sage-try-data"

# ---------------------------------------------------------------------------
# Sage project registry (~/.sage-is/)
# Remembers where you cloned things so you never lose your code.
# ---------------------------------------------------------------------------
SAGE_CONFIG_DIR="${HOME}/.sage-is"
SAGE_PROJECTS="${SAGE_CONFIG_DIR}/projects"
TRY_ENV_FILE="${SAGE_CONFIG_DIR}/try.env"

# The upstream remote URL pattern (matches any protocol/suffix).
AI_UI_REMOTE="Sage-is/AI-UI"

# Read saved clone path for a project. Prints nothing if unset.
sage_project_dir() {
  [[ -f "$SAGE_PROJECTS" ]] && sed -n "s/^${1}=//p" "$SAGE_PROJECTS"
}

# Save (or update) the clone path for a project.
sage_set_project_dir() {
  local project="$1" dir="$2"
  mkdir -p "$SAGE_CONFIG_DIR"
  # Remove existing entry, then append. sed -i.bak for macOS compat.
  if [[ -f "$SAGE_PROJECTS" ]]; then
    sed -i.bak "/^${project}=/d" "$SAGE_PROJECTS" && rm -f "${SAGE_PROJECTS}.bak"
  fi
  echo "${project}=${dir}" >> "$SAGE_PROJECTS"
}

# Check if a directory is a clone of a given repo (by git remote, not folder name).
is_repo_for() {
  local dir="$1" pattern="$2"
  [[ -d "$dir/.git" ]] && git -C "$dir" remote -v 2>/dev/null | grep -qi "$pattern"
}

# Find a matching repo nearby: check cwd (walk up to git root), then scan subdirs.
# Detects by content (git remote), not directory name — works with any folder name.
find_repo_nearby() {
  local pattern="$1"

  # Are we already inside a matching repo?
  local git_root
  git_root="$(git rev-parse --show-toplevel 2>/dev/null)" || true
  if [[ -n "$git_root" ]] && is_repo_for "$git_root" "$pattern"; then
    echo "$git_root"; return 0
  fi

  # Scan immediate subdirectories (one level) for any matching clone.
  local subdir
  for subdir in ./*/; do
    [[ -d "$subdir/.git" ]] || continue
    if is_repo_for "$subdir" "$pattern"; then
      (cd "$subdir" && pwd); return 0
    fi
  done

  return 1
}

# Check if a path is ephemeral (won't survive reboot).
is_ephemeral_path() {
  case "$1" in
    /tmp/*|/private/tmp/*|/var/folders/*) return 0 ;;
    *) return 1 ;;
  esac
}

usage() {
  cat <<EOF
Usage: ai-ui <command> [options]

Commands:
  start [--port PORT] [--tag X.Y.Z]
                        Pull image and start Sage AI UI (default port: $DEFAULT_PORT)
                        --tag pins a specific server version (default: $DEFAULT_SERVER_TAG)
  stop                  Stop the running container (prod and trial)
  try   [--port PORT] [--tag X.Y.Z]
                        Start try.sage trial mode (BYO Groq key on first run)
  update [--tag X.Y.Z]  Pull a tag (default latest) and restart
  dev   [--port PORT] [--dir DIR] [--where]
                        Clone and run in dev mode with hot reload
  logs                  Tail container logs
  open                  Open the UI in your default browser
  status                Show container status
  version               Show CLI version
  nuke                  Remove everything Sage AI UI — clean slate

EOF
}

cmd_version() {
  echo "ai-ui $VERSION"
}

# Ensure Docker is reachable. Auto-starts or installs a provider if needed.
ensure_docker() {
  if docker info &>/dev/null; then
    return 0
  fi

  case "$(uname)" in
    Darwin)
      if [ -d "/Applications/Docker.app" ]; then
        echo "Starting Docker Desktop..."
        open -a Docker
      elif [ -d "/Applications/OrbStack.app" ]; then
        echo "Starting OrbStack..."
        open -a OrbStack
      elif command -v colima &>/dev/null; then
        echo "Starting Colima..."
        colima start
      elif command -v brew &>/dev/null; then
        echo "No Docker provider found. Installing Docker Desktop via Homebrew..."
        brew install --cask docker
        echo "Starting Docker Desktop..."
        open -a Docker
      else
        echo "Error: No Docker provider found and Homebrew is not available."
        echo "  Install Docker Desktop: https://docs.docker.com/get-docker/"
        exit 1
      fi

      echo "Waiting for Docker daemon..."
      for i in $(seq 1 30); do
        if docker info &>/dev/null; then
          echo "Docker is ready."
          return 0
        fi
        sleep 1
      done

      echo "Error: Docker daemon did not start within 30 seconds."
      echo "  Try starting it manually and run 'ai-ui start' again."
      exit 1
      ;;

    Linux)
      if ! command -v docker &>/dev/null && command -v brew &>/dev/null; then
        echo "Docker not found. Installing via Homebrew..."
        brew install docker
        echo "Note: You also need Docker Engine running."
        echo "  See: https://docs.docker.com/engine/install/"
        exit 1
      fi
      echo "Error: Docker daemon is not running."
      echo "  Start it with: sudo systemctl start docker"
      echo "  Enable on boot: sudo systemctl enable docker"
      exit 1
      ;;

    *)
      echo "Error: Cannot connect to Docker."
      exit 1
      ;;
  esac
}

cmd_start() {
  local port=$DEFAULT_PORT
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --port) port="$2"; shift 2 ;;
      --tag)  IMAGE_TAG="$2"; IMAGE="$IMAGE_REGISTRY:$IMAGE_TAG"; shift 2 ;;
      *) echo "Unknown option: $1"; usage; exit 1 ;;
    esac
  done

  ensure_docker

  echo "Pulling $IMAGE..."
  docker pull "$IMAGE"

  # Stop existing container if running
  docker rm -f "$CONTAINER" 2>/dev/null || true

  echo "Starting Sage AI UI on port $port..."
  docker run -d \
    -p "$port:8080" \
    -v "$VOLUME:$DATA_MOUNT" \
    --name "$CONTAINER" \
    "$IMAGE"

  echo ""
  echo "Sage AI UI is running at http://localhost:$port"
  echo "Run 'ai-ui open' to open in your browser."
}

cmd_stop() {
  echo "Stopping Sage AI UI..."
  for c in "$CONTAINER" "$TRY_CONTAINER"; do
    docker stop "$c" 2>/dev/null || true
    docker rm "$c" 2>/dev/null || true
  done
  echo "Stopped."
}

cmd_dev() {
  local port=$DEFAULT_PORT
  local explicit_dir=""
  local repo_dir=""
  local saved
  saved="$(sage_project_dir ai-ui)" || true
  local needs_clone=false

  # --- Parse flags ---
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --port)  port="$2"; shift 2 ;;
      --dir)   explicit_dir="$2"; shift 2 ;;
      --where)
        # Quick lookup: where's my code?
        if [[ -n "$saved" ]]; then
          echo "$saved"
        else
          echo "No saved location yet. Run 'ai-ui dev' to set one up."
        fi
        return 0
        ;;
      *) echo "Unknown option: $1"; usage; exit 1 ;;
    esac
  done

  # --- Step 1: Explicit --dir? Trust the user. ---
  if [[ -n "$explicit_dir" ]]; then
    repo_dir="$explicit_dir"
    if [[ -n "$saved" && "$saved" != "$repo_dir" ]]; then
      echo "Note: switching from $saved (previously saved) to $repo_dir."
    fi

  # --- Step 2: SAGE_DEV_DIR env var? Backwards compat. ---
  elif [[ -n "${SAGE_DEV_DIR:-}" ]]; then
    repo_dir="$SAGE_DEV_DIR"
    if [[ -n "$saved" && "$saved" != "$repo_dir" ]]; then
      echo "Note: SAGE_DEV_DIR is set — switching from $saved to $repo_dir."
    fi

  # --- Step 3: Are we inside (or next to) an AI-UI repo right now? ---
  elif repo_dir="$(find_repo_nearby "$AI_UI_REMOTE")"; then
    if [[ -n "$saved" && "$saved" != "$repo_dir" ]]; then
      echo "Found AI-UI source here ($repo_dir)."
      echo "  Note: previously saved as $saved — updating."
    elif [[ -z "$saved" ]]; then
      echo "Found AI-UI source here ($repo_dir). Saving for next time."
    else
      echo "Using AI-UI source at $repo_dir"
    fi

  # --- Step 4: Do we have a saved path from last time? ---
  elif [[ -n "$saved" ]]; then
    if [[ -d "$saved" ]]; then
      echo "Using your AI-UI source at $saved (saved from last time)."
      repo_dir="$saved"
    else
      # The directory is gone — don't silently forget.
      echo "Heads up — your AI-UI source was at $saved, but that directory is gone."
      echo "  (If you moved it, you can point us there with: ai-ui dev --dir /new/path)"
      echo ""
      repo_dir="${HOME}/src/ai-ui"
      needs_clone=true
    fi

  # --- Step 5: First time, nothing found. Clone fresh. ---
  else
    repo_dir="${HOME}/src/ai-ui"
    needs_clone=true
  fi

  # --- Clone if needed ---
  if [[ "$needs_clone" == true ]] || [[ ! -d "$repo_dir" ]]; then
    echo "Cloning Sage AI UI to $repo_dir..."
    git clone https://github.com/Sage-is/AI-UI.git "$repo_dir"
    echo "  (We'll remember this location for next time.)"
  fi

  # --- Step 6: Ephemeral path warning ---
  if is_ephemeral_path "$repo_dir"; then
    echo ""
    echo "  ⚠ Heads up: $repo_dir may not survive a reboot."
    echo "    Your code changes could be lost."
    echo "    For a permanent location: ai-ui dev --dir ~/src/ai-ui"
    echo ""
  fi

  # --- Save the resolved path for next time ---
  sage_set_project_dir ai-ui "$repo_dir"

  # --- Start dev container ---
  ensure_docker

  docker rm -f "$CONTAINER" 2>/dev/null || true

  echo "Pulling latest image..."
  docker pull "$IMAGE"

  echo "Starting in dev mode on port $port..."
  docker run -d \
    -p "$port:8080" \
    -p 5173:5173 \
    -v "$VOLUME:$DATA_MOUNT" \
    -v "$repo_dir/app/src:/app/src" \
    -v "$repo_dir/app/backend:/app/backend" \
    -v "$repo_dir/app/static:/app/static" \
    -e DEV_MODE=true \
    --name "$CONTAINER" \
    "$IMAGE"

  echo ""
  echo "Dev mode running. Source: $repo_dir"
  echo "App:      http://localhost:$port"
  echo "Vite HMR: http://localhost:5173 (when Node.js installed)"
  echo ""
  echo "Run 'ai-ui logs' to see output."
  echo "Run 'ai-ui open' to open in your browser."
}

# ---------------------------------------------------------------------------
# try.sage trial mode
# ---------------------------------------------------------------------------
# Bring up a trial container with seeded personas, hidden LLM connection, and
# 24h auto-reset. BYO Groq API key (saved chmod 600 to ~/.sage-is/try.env).
# Future: 'ai-ui login' will provide hosted free tokens after onboarding.

ensure_try_credentials() {
  mkdir -p "$SAGE_CONFIG_DIR"

  if [[ -f "$TRY_ENV_FILE" ]]; then
    set -a
    # shellcheck source=/dev/null
    source "$TRY_ENV_FILE"
    set +a
    if [[ -n "${TRY_SAGE_LLM_API_URL:-}" && -n "${TRY_SAGE_LLM_API_KEY:-}" ]]; then
      return 0
    fi
    echo "Found $TRY_ENV_FILE but it's missing required values. Re-prompting."
    echo ""
  fi

  cat <<EOF
try.sage needs an OpenAI-compatible LLM provider. We recommend Groq (fast, free tier):

  1. Sign up free at https://console.groq.com
  2. Create an API key at https://console.groq.com/keys
  3. Paste it below.

We'll save it to $TRY_ENV_FILE (chmod 600). Edit or delete that file to change it.

(Coming soon: 'ai-ui login' for hosted free tokens — no Groq account needed.)

EOF
  local key=""
  read -rp "Groq API key (starts with gsk_): " key
  if [[ -z "$key" ]]; then
    echo "No key provided. Aborting."
    exit 1
  fi

  cat > "$TRY_ENV_FILE" <<EOF
# Generated by 'ai-ui try'. Edit or delete this file to re-prompt.
TRY_SAGE_LLM_API_URL=https://api.groq.com/openai/v1
TRY_SAGE_LLM_API_KEY=$key
# Optional. Comma-separated whitelist of models. Empty = expose the full provider list.
TRY_SAGE_LLM_MODELS=
# Optional. Number of trial seats (personas). Default 3.
TRY_SAGE_USER_SEAT_COUNT=3
# Optional. Hours between auto-resets. Default 24.
TRY_SAGE_RESET_INTERVAL_HOURS=24
EOF
  chmod 600 "$TRY_ENV_FILE"
  echo "Saved to $TRY_ENV_FILE"
  echo ""

  set -a
  # shellcheck source=/dev/null
  source "$TRY_ENV_FILE"
  set +a
}

# Print the persona magic-link URLs for the running trial container.
print_try_links() {
  local port="$1"
  echo "Trial welcome URL: http://localhost:$port/auth (open in incognito)"
  echo ""
  echo "Persona magic-links:"
  curl -fsS "http://localhost:$port/api/v1/sage/runtime/personas" 2>/dev/null \
    | python3 -c "import json, sys; [print(f\"  {p['key']:12}  {p['login_url']}\") for p in json.load(sys.stdin)]" \
    || echo "  (container not yet responding on :$port — give it a moment, then re-run 'ai-ui try')"
}

cmd_try() {
  local port=$DEFAULT_PORT
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --port) port="$2"; shift 2 ;;
      --tag)  IMAGE_TAG="$2"; IMAGE="$IMAGE_REGISTRY:$IMAGE_TAG"; shift 2 ;;
      *) echo "Unknown option: $1"; usage; exit 1 ;;
    esac
  done

  # Already running (e.g. backgrounded in another terminal)? Just print links.
  if docker inspect --format='{{.State.Status}}' "$TRY_CONTAINER" 2>/dev/null | grep -q running; then
    local existing_port
    existing_port=$(docker port "$TRY_CONTAINER" 8080 2>/dev/null | head -1 | cut -d: -f2)
    existing_port="${existing_port:-$port}"
    echo "try.sage is already running on port $existing_port."
    echo ""
    print_try_links "$existing_port"
    return 0
  fi

  ensure_try_credentials
  ensure_docker

  echo "Pulling latest image..."
  docker pull "$IMAGE"

  # Both prod and trial bind 8080 — drop whichever is in the way.
  docker rm -f "$CONTAINER" 2>/dev/null || true
  docker rm -f "$TRY_CONTAINER" 2>/dev/null || true

  local webui_url="${WEBUI_URL:-http://localhost:$port}"

  echo ""
  echo "Booting try.sage on $webui_url"
  echo "Magic links will print below once the runtime seeds personas."
  echo "Press Ctrl-C to stop."
  echo ""

  # Background poller waits for the API, prints persona links, then exits.
  # Decoupled from the foreground `docker run` so Ctrl-C cleanly tears down
  # the container (--rm) without us juggling pids.
  (
    for _ in $(seq 1 30); do
      if curl -fsS "http://localhost:$port/api/v1/sage/runtime/personas" >/dev/null 2>&1; then
        echo ""
        echo "═══════════════════════════════════════════════════════════"
        print_try_links "$port"
        echo "═══════════════════════════════════════════════════════════"
        echo ""
        exit 0
      fi
      sleep 1
    done
  ) &

  # Foreground run. Ctrl-C stops the container; --rm cleans the row.
  docker run --rm \
    -p "$port:8080" \
    -v "$TRY_VOLUME:$DATA_MOUNT" \
    -e ENABLE_TRY_SAGE=true \
    -e WEBUI_URL="$webui_url" \
    -e TRY_SAGE_LLM_API_URL="$TRY_SAGE_LLM_API_URL" \
    -e TRY_SAGE_LLM_API_KEY="$TRY_SAGE_LLM_API_KEY" \
    -e TRY_SAGE_LLM_MODELS="${TRY_SAGE_LLM_MODELS:-}" \
    -e TRY_SAGE_USER_SEAT_COUNT="${TRY_SAGE_USER_SEAT_COUNT:-3}" \
    -e TRY_SAGE_RESET_INTERVAL_HOURS="${TRY_SAGE_RESET_INTERVAL_HOURS:-24}" \
    --name "$TRY_CONTAINER" \
    "$IMAGE"
}

# Nuke from orbit — delegates to the Genesis Device (standalone, works without ai-ui installed).
cmd_nuke() {
  local script_dir
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -x "$script_dir/scripts/nuke-sage" ]]; then
    exec "$script_dir/scripts/nuke-sage" ai-ui "$@"
  else
    echo "Error: scripts/nuke-sage not found relative to $(basename "$0")."
    echo "  Run it directly: scripts/nuke-sage ai-ui"
    exit 1
  fi
}

cmd_update() {
  # Pre-parse --tag so the pull line shows the right image; cmd_start re-parses.
  local i=0
  while [[ $i -lt $# ]]; do
    i=$((i + 1))
    if [[ "${!i:-}" == "--tag" ]]; then
      local next=$((i + 1))
      IMAGE_TAG="${!next}"
      IMAGE="$IMAGE_REGISTRY:$IMAGE_TAG"
      break
    fi
  done

  echo "Pulling $IMAGE..."
  docker pull "$IMAGE"
  cmd_stop
  cmd_start "$@"
}

cmd_logs() {
  docker logs -f "$CONTAINER"
}

cmd_open() {
  local port
  port=$(docker port "$CONTAINER" 8080 2>/dev/null | head -1 | cut -d: -f2)
  if [[ -z "$port" ]]; then
    echo "Container is not running. Start it first with: ai-ui start"
    exit 1
  fi
  local url="http://localhost:$port"
  case "$(uname)" in
    Darwin) open "$url" ;;
    *)      xdg-open "$url" 2>/dev/null || echo "Open $url in your browser." ;;
  esac
}

cmd_status() {
  docker inspect --format='Status: {{.State.Status}}' "$CONTAINER" 2>/dev/null || echo "Container is not running."
  local port
  port=$(docker port "$CONTAINER" 8080 2>/dev/null | head -1 | cut -d: -f2)
  if [[ -n "$port" ]]; then
    echo "URL: http://localhost:$port"
  fi
}

if [[ $# -eq 0 ]]; then
  usage
  exit 0
fi

command="$1"; shift
case "$command" in
  start)  cmd_start "$@" ;;
  stop)   cmd_stop ;;
  try)    cmd_try "$@" ;;
  update) cmd_update "$@" ;;
  dev)    cmd_dev "$@" ;;
  logs)   cmd_logs ;;
  open)   cmd_open ;;
  status) cmd_status ;;
  nuke)   cmd_nuke ;;
  version|-v|--version) cmd_version ;;
  -h|--help|help) usage ;;
  *) echo "Unknown command: $command"; usage; exit 1 ;;
esac
