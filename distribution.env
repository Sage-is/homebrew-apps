# Canonical distribution facts shared across the Sage.is ecosystem.
#
# Source of truth: homebrew-apps/distribution.env
# Hardlinked into:
#   - WEB-AI--Sage-is-AI-UI/distribution.env
#   - WEB-Sage.Education-docs/distribution.env
#
# Edit this file here; the hardlink chain propagates the change to the two
# siblings. If a sibling has drifted (link count != 3), run `make
# distribution_sync` from any repo to re-establish the chain.
#
# Plain shell-readable assignments. No quotes unless the value contains
# whitespace. Comments allowed.

# ─── CLI track ────────────────────────────────────────────────────────────
# homebrew-apps version. Bumps only when the ai-ui shell wrapper changes.
CLI_VERSION=1.1.0

# ─── Server track ─────────────────────────────────────────────────────────
# WEB-AI--Sage-is-AI-UI server image. Bumps on app changes; published to GHCR.
SERVER_TAG=2.3.1
IMAGE=ghcr.io/sage-is/ai-ui

# ─── Data volume ──────────────────────────────────────────────────────────
# Canonical volume name and mount path. Brew CLI, Makefile, and docs read here.
VOLUME=sage-ai-data
DATA_MOUNT=/app/backend/data

# ─── User-facing install command ──────────────────────────────────────────
# Surfaced in docs, formula caveats, and the AI-UI README.
INSTALL_COMMAND="brew install sage-is/apps/ai-ui"

# ─── Native app waitlist ──────────────────────────────────────────────────
# Placeholder. Update with the real landing page before the docs install
# pages reference it.
WAITLIST_URL=https://sage.is/app

# ─── ML bundle (Shape B — ships in 2.4) ───────────────────────────────────
# 2.3.1 ships the transitional pip-install wizard path. 2.4 replaces it with
# signed per-arch tarballs pulled into the container at activation time.
# Until 2.4, these stay empty.
ML_BUNDLE_TAG=
ML_BUNDLE_SHA_AMD64_CPU=
ML_BUNDLE_SHA_ARM64_CPU=
ML_BUNDLE_SHA_AMD64_CUDA=
ML_BUNDLE_SHA_ARM64_CUDA=
BUNDLE_URL=https://github.com/Sage-is/AI-UI/releases/download
