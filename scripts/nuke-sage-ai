#!/bin/bash
# nuke-sage-ai — Remove everything Sage AI UI from this machine.
#
# Works standalone (no dependencies) so you can run it even if ai-ui
# isn't installed, brew is broken, or you're on a fresh test machine.
#
# What it cleans:
#   1. Docker: container, volume, image
#   2. Source code: saved clone path + default ~/src/ai-ui
#   3. Config: ~/.sage-is/projects ai-ui entry
#   4. Homebrew: ai-ui formula + sage-is/apps tap
#
# Usage:
#   scripts/nuke-sage-ai          # interactive — confirms before removing
#   scripts/nuke-sage-ai --yes    # skip confirmation (for CI/scripting)
#
set -euo pipefail

# --- Constants (must match ai-ui script) ---
CONTAINER="sage-ai"
VOLUME="sage-ai-data"
IMAGE="ghcr.io/sage-is/ai-ui:latest"
SAGE_CONFIG_DIR="${HOME}/.sage-is"
SAGE_PROJECTS="${SAGE_CONFIG_DIR}/projects"
DEFAULT_SOURCE="${HOME}/src/ai-ui"

# --- Parse flags ---
AUTO_YES=false
if [[ "${1:-}" == "--yes" || "${1:-}" == "-y" ]]; then
  AUTO_YES=true
fi

# --- Helpers ---

# Read saved clone path for ai-ui from ~/.sage-is/projects.
saved_source_path() {
  [[ -f "$SAGE_PROJECTS" ]] && sed -n "s/^ai-ui=//p" "$SAGE_PROJECTS"
}

echo ""
echo "  ╔══════════════════════════════════════════╗"
echo "  ║  nuke-sage-ai-from-orbit                 ║"
echo "  ║  Remove everything. Clean slate.         ║"
echo "  ╚══════════════════════════════════════════╝"
echo ""

# --- Gather what exists ---
items=()
has_container=false has_volume=false has_image=false
has_source=false source_path=""
has_default_source=false
has_config=false
has_brew=false has_tap=false

# Docker (only if docker is available)
if command -v docker &>/dev/null; then
  if docker inspect "$CONTAINER" &>/dev/null 2>&1; then
    has_container=true
    items+=("  Docker container:  $CONTAINER")
  fi
  if docker volume inspect "$VOLUME" &>/dev/null 2>&1; then
    has_volume=true
    items+=("  Docker volume:     $VOLUME (your data!)")
  fi
  if docker image inspect "$IMAGE" &>/dev/null 2>&1; then
    has_image=true
    items+=("  Docker image:      $IMAGE")
  fi
fi

# Saved source path
saved="$(saved_source_path)" || true
if [[ -n "$saved" && -d "$saved" ]]; then
  has_source=true
  source_path="$saved"
  items+=("  Source code:       $saved")
fi

# Default source path (if different from saved)
if [[ -d "$DEFAULT_SOURCE" && "$DEFAULT_SOURCE" != "$saved" ]]; then
  has_default_source=true
  items+=("  Source code:       $DEFAULT_SOURCE (default location)")
fi

# Sage config
if [[ -f "$SAGE_PROJECTS" ]] && grep -q "^ai-ui=" "$SAGE_PROJECTS" 2>/dev/null; then
  has_config=true
  items+=("  Config entry:      ~/.sage-is/projects (ai-ui line)")
fi

# Homebrew (only if brew is available)
if command -v brew &>/dev/null; then
  if brew list ai-ui &>/dev/null 2>&1; then
    has_brew=true
    items+=("  Homebrew formula:  ai-ui")
  fi
  if brew tap 2>/dev/null | grep -q "sage-is/apps"; then
    has_tap=true
    items+=("  Homebrew tap:      sage-is/apps")
  fi
fi

# Nothing to do?
if [[ ${#items[@]} -eq 0 ]]; then
  echo "Nothing to remove — already clean."
  exit 0
fi

# --- Show what we found ---
echo "Here's what we'll remove:"
echo ""
for item in "${items[@]}"; do
  echo "$item"
done
echo ""

if [[ "$has_volume" == true ]]; then
  echo "  ⚠ The Docker volume contains your data (conversations, settings)."
  echo "    This cannot be undone."
  echo ""
fi

if [[ "$has_source" == true || "$has_default_source" == true ]]; then
  echo "  ⚠ Source directories may contain uncommitted work."
  echo "    We won't delete them automatically — we'll tell you how."
  echo ""
fi

# --- Confirm ---
if [[ "$AUTO_YES" == false ]]; then
  read -r -p "Proceed? (yes/no): " confirm
  if [[ "$confirm" != "yes" ]]; then
    echo "Aborted. Nothing was touched."
    exit 0
  fi
  echo ""
fi

# --- Step 1: Docker ---
if [[ "$has_container" == true ]]; then
  echo "Stopping and removing container..."
  docker stop "$CONTAINER" 2>/dev/null || true
  docker rm "$CONTAINER" 2>/dev/null || true
  echo "  Done."
fi

if [[ "$has_volume" == true ]]; then
  echo "Removing volume $VOLUME..."
  docker volume rm "$VOLUME" 2>/dev/null || true
  echo "  Done."
fi

if [[ "$has_image" == true ]]; then
  echo "Removing image $IMAGE..."
  docker rmi "$IMAGE" 2>/dev/null || true
  echo "  Done."
fi

# --- Step 2: Source code (show, don't delete — respect their work) ---
if [[ "$has_source" == true ]]; then
  echo ""
  echo "Source code at $source_path was left in place."
  echo "  To remove it:  rm -rf \"$source_path\""
fi
if [[ "$has_default_source" == true ]]; then
  echo "Source code at $DEFAULT_SOURCE was left in place."
  echo "  To remove it:  rm -rf \"$DEFAULT_SOURCE\""
fi

# --- Step 3: Config ---
if [[ "$has_config" == true ]]; then
  echo "Removing ai-ui entry from ~/.sage-is/projects..."
  sed -i.bak "/^ai-ui=/d" "$SAGE_PROJECTS" && rm -f "${SAGE_PROJECTS}.bak"
  # If the projects file is now empty, clean up
  if [[ ! -s "$SAGE_PROJECTS" ]]; then
    rm -f "$SAGE_PROJECTS"
    # Only remove the dir if it's empty (other Sage tools may use it)
    rmdir "$SAGE_CONFIG_DIR" 2>/dev/null || true
    echo "  Removed ~/.sage-is/ (was empty)."
  else
    echo "  Done. (Other projects still in ~/.sage-is/projects.)"
  fi
fi

# --- Step 4: Homebrew ---
if [[ "$has_brew" == true ]]; then
  echo "Uninstalling ai-ui formula..."
  brew uninstall ai-ui 2>/dev/null || true
  echo "  Done."
fi
if [[ "$has_tap" == true ]]; then
  echo "Removing sage-is/apps tap..."
  brew untap sage-is/apps 2>/dev/null || true
  echo "  Done."
fi

echo ""
echo "All clean. To start fresh:"
echo "  brew install sage-is/apps/ai-ui"
echo ""
